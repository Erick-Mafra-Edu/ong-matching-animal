# ==============================================================
# BACKEND ENVIRONMENT
# ==============================================================

# Supabase credentials
# Obtenha em: https://app.supabase.com/
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Node environment
NODE_ENV=development

# Server port
PORT=3000

# ==============================================================
# FRONTEND ENVIRONMENT
# ==============================================================

# URL publica do backend usada pelo frontend nas chamadas fetch
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# Supabase Auth no navegador
# Use a publishable key (sb_publishable_...) ou, em projetos legados, a anon key.
# Nunca exponha SUPABASE_SERVICE_ROLE_KEY no frontend.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here

# ==============================================================
# GOOGLE CALENDAR OAUTH + SYNC
# ==============================================================

GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/oauth/google/callback

# Usado para proteger a Edge Function sync-google-calendar
CALENDAR_SYNC_SECRET=change_me
CALENDAR_SYNC_BATCH_SIZE=20
CALENDAR_SYNC_MAX_ATTEMPTS=5
CALENDAR_SYNC_VISIBILITY_TIMEOUT_SECONDS=120
CALENDAR_SYNC_TIME_ZONE=America/Sao_Paulo
